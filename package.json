{
  "name": "patchstory-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Generate a static, interactive PR walkthrough from a git diff or GitHub PR.",
  "keywords": ["pull-request", "code-review", "diff", "walkthrough", "static-site", "cli", "git"],
  "homepage": "https://github.com/russ/patchstory#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/russ/patchstory.git"
  },
  "bugs": {
    "url": "https://github.com/russ/patchstory/issues"
  },
  "author": "Russell Smith",
  "workspaces": [
    "packages/core",
    "packages/renderer",
    "packages/cli"
  ],
  "scripts": {
    "build": "node build.mjs",
    "prepare": "node build.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test tests/*.test.ts",
    "patchstory": "node packages/cli/dist/patchstory.mjs"
  },
  "license": "MIT",
  "bin": {
    "patchstory": "packages/cli/dist/patchstory.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "highlight.js": "^11.11.1",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
