@@ -0,0 +1,18 @@
+# Per-environment rate-limiting policy. The RateLimiter middleware reads each
+# client's ceiling from ApiClient#rate_limit at runtime; this file toggles
+# enforcement per environment and documents the tier ceilings used by seeds.
+default: &default
+  retry_after_seconds: 60
+  burst_multiplier: 1.5
+
+development:
+  <<: *default
+  enabled: false
+
+production:
+  <<: *default
+  enabled: true
+  tiers:
+    standard: 60
+    pro: 600
+    enterprise: 6000
diff --git a/spec/middleware/rate_limiter_spec.rb b/spec/middleware/rate_limiter_spec.rb
new file mode 100644
index 0000000..e6f7a8b
--- /dev/null
+++ b/spec/middleware/rate_limiter_spec.rb
@@ -0,0 +1,38 @@
+require "rails_helper"
+
+RSpec.describe RateLimiter do
+  let(:redis) { MockRedis.new }
+  let(:client) { create(:api_client, rate_limit_tier: "standard") }
+  let(:app) { ->(_env) { [200, {}, ["ok"]] } }
+  subject(:middleware) { described_class.new(app, redis: redis) }
+
+  def env_for(path, api_client: client)
+    Rack::MockRequest.env_for(path).merge("api.client" => api_client)
+  end
+
+  it "passes requests under the limit through and annotates the response" do
+    status, headers, _ = middleware.call(env_for("/api/v1/posts"))
+    expect(status).to eq(200)
+    expect(headers["X-RateLimit-Limit"]).to eq("60")
+    expect(headers["X-RateLimit-Remaining"]).to eq("59")
+  end
+
+  it "returns 429 once the per-minute ceiling is exceeded" do
+    60.times { middleware.call(env_for("/api/v1/posts")) }
+    status, _, body = middleware.call(env_for("/api/v1/posts"))
+    expect(status).to eq(429)
+    expect(JSON.parse(body.first)).to include("error" => "rate_limit_exceeded")
+  end
+
+  it "leaves unauthenticated and non-API requests untouched" do
+    status, headers, _ = middleware.call(env_for("/health", api_client: nil))
+    expect(status).to eq(200)
+    expect(headers).not_to include("X-RateLimit-Limit")
+  end
+
+  it "honours a per-client override above the tier default" do
+    client.update!(requests_per_minute: 120)
+    status, headers, _ = middleware.call(env_for("/api/v1/posts"))
+    expect(headers["X-RateLimit-Limit"]).to eq("120")
+    expect(status).to eq(200)
+  end
+end
