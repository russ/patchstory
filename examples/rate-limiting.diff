@@ -1,11 +1,33 @@
 class ApiClient < ApplicationRecord
   belongs_to :organization
   has_many :api_requests, dependent: :destroy

+  # Requests-per-minute ceiling for each tier. A per-record
+  # `requests_per_minute` value can raise (but never lower) the tier default.
+  TIER_LIMITS = {
+    "standard"   => 60,
+    "pro"        => 600,
+    "enterprise" => 6_000,
+  }.freeze
+
   validates :name, presence: true
+  validates :rate_limit_tier, inclusion: { in: TIER_LIMITS.keys }
+
+  # Effective per-minute limit: the higher of the tier default and any
+  # explicit override stored on the record.
+  def rate_limit
+    [TIER_LIMITS.fetch(rate_limit_tier, 60), requests_per_minute.to_i].max
+  end
+
+  # Redis key for this client's counter in a given one-minute window.
+  def rate_limit_key(window)
+    "ratelimit:#{id}:#{window}"
+  end

   def active?
     revoked_at.nil?
   end
 end
