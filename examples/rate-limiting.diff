+++ b/app/middleware/rate_limiter.rb
@@ -0,0 +1,58 @@
+# Rack middleware that enforces a per-client, per-minute request ceiling using
+# Redis counters. Unauthenticated requests and non-API paths pass straight
+# through, so this only ever throttles identified API traffic.
+class RateLimiter
+  def initialize(app, redis: Redis.current)
+    @app = app
+    @redis = redis
+  end
+
+  def call(env)
+    request = Rack::Request.new(env)
+    client = env["api.client"]
+
+    return @app.call(env) unless client && api_path?(request.path)
+
+    window = Time.now.utc.strftime("%Y%m%d%H%M")
+    count = increment(client.rate_limit_key(window))
+
+    return too_many_requests(client, count) if count > client.rate_limit
+
+    status, headers, body = @app.call(env)
+    headers.merge!(rate_limit_headers(client, count))
+    [status, headers, body]
+  end
+
+  private
+
+  # INCR + EXPIRE in one round-trip so the key always gets a TTL even on the
+  # first request of a window. Returns the post-increment count.
+  def increment(key)
+    count, _ = @redis.multi do |tx|
+      tx.incr(key)
+      tx.expire(key, 60)
+    end
+    count
+  end
+
+  def too_many_requests(client, count)
+    body = { error: "rate_limit_exceeded", limit: client.rate_limit }.to_json
+    headers = rate_limit_headers(client, count).merge(
+      "Content-Type" => "application/json",
+      "Retry-After"  => "60",
+    )
+    [429, headers, [body]]
+  end
+
+  def rate_limit_headers(client, count)
+    {
+      "X-RateLimit-Limit"     => client.rate_limit.to_s,
+      "X-RateLimit-Remaining" => [client.rate_limit - count, 0].max.to_s,
+    }
+  end
+
+  def api_path?(path)
+    path.start_with?("/api/")
+  end
+end
