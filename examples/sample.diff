diff --git a/app/services/face_detection_service.rb b/app/services/face_detection_service.rb
new file mode 100644
index 0000000..abcdef1
--- /dev/null
+++ b/app/services/face_detection_service.rb
@@ -0,0 +1,34 @@
+# Detects faces in uploaded media and records the count on the record.
+class FaceDetectionService
+  Result = Struct.new(:face_count, :ok, keyword_init: true)
+
+  def initialize(provider: Vision::Provider.default)
+    @provider = provider
+  end
+
+  def call(media)
+    response = @provider.detect_faces(media.attachment_blob)
+    count = response.faces.size
+    media.update!(face_count: count)
+    media.pending! if count > 1
+    Result.new(face_count: count, ok: true)
+  rescue Vision::Provider::Error => e
+    Rails.logger.warn("face detection failed for media=#{media.id}: #{e.message}")
+    # Fail open: don't block uploads when detection is unavailable.
+    Result.new(face_count: 0, ok: false)
+  end
+
+  def self.call(media)
+    new.call(media)
+  end
+end
