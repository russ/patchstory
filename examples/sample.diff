diff --git a/spec/services/face_detection_service_spec.rb b/spec/services/face_detection_service_spec.rb
new file mode 100644
index 0000000..7654321
--- /dev/null
+++ b/spec/services/face_detection_service_spec.rb
@@ -0,0 +1,29 @@
+require "rails_helper"
+
+RSpec.describe FaceDetectionService do
+  let(:media) { create(:media) }
+
+  it "records a single-face upload as publishable" do
+    stub_provider(faces: 1)
+    FaceDetectionService.call(media)
+    expect(media.reload.face_count).to eq(1)
+    expect(media).to be_publishable
+  end
+
+  it "flags multi-face uploads for review" do
+    stub_provider(faces: 3)
+    FaceDetectionService.call(media)
+    expect(media.reload).to be_pending
+    expect(media).not_to be_publishable
+  end
+
+  it "fails open when detection errors" do
+    allow_provider_to_raise(Vision::Provider::Error)
+    result = FaceDetectionService.call(media)
+    expect(result.ok).to eq(false)
+    expect(media.reload.face_count).to eq(0)
+  end
+end
